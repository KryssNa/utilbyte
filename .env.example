# UtilByte Environment Variables
# Copy this file to .env.local and fill in the values you need.
# Most tools work without any environment variables.

# ──────────────────────────────────────────────
# Base URL (used for sitemap, canonical URLs, OG tags)
# ──────────────────────────────────────────────
# NEXT_PUBLIC_BASE_URL=https://utilbyte.app

# ──────────────────────────────────────────────
# Supabase (only needed for: Request Catcher, API Client, Local Proxy)
# ──────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ──────────────────────────────────────────────
# Analytics (optional)
# ──────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ──────────────────────────────────────────────
# Sentry (optional — error monitoring)
# ──────────────────────────────────────────────
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ──────────────────────────────────────────────
# Contact Form (optional — Slack webhook for contact submissions)
# ──────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
